---
import Container from "../layout/Container.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import ArticleCard from "../content/ArticleCard.astro";
import ProjectCard from "../content/ProjectCard.astro";
import { ui } from "../../i18n/ui";
import {
  BILIBILI_URL,
  GITHUB_URL,
  getCollectionPath,
  PROFILE_AVATAR_SRC,
  type SiteLang,
} from "../../i18n/utils";
import {
  getBlogEntryPath,
  getLatestBlogEntries,
  getLatestEntries,
  getEntryPath,
} from "../../lib/content/translations";

interface Props {
  lang: SiteLang;
}

const { lang } = Astro.props;
const copy = ui[lang];
const moreLabel = lang === "zh-CN" ? "更多" : "More";
const [latestProjects, latestBlog, latestLife] = await Promise.all([
  getLatestEntries("projects", lang, 4),
  getLatestBlogEntries(lang, 6),
  getLatestEntries("life", lang, 3),
]);
const primaryBlog = latestBlog[0];
const secondaryBlog = latestBlog.slice(1, 5);
const primaryProject = latestProjects[0];
const secondaryProjects = latestProjects.slice(1, 4);
---

<section class="pb-4 pt-7 sm:pt-8 lg:pb-6 lg:pt-7">
  <Container>
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_17.5rem] lg:items-start xl:gap-10">
      <div class="pt-2">
        <p class="eyebrow">{copy.hero.eyebrow}</p>
        <h1 class="mt-3 max-w-[46rem] text-[3rem] font-semibold tracking-tight text-[var(--text-main)] sm:text-[3.35rem] lg:text-[3.55rem]">
          {copy.hero.title}
        </h1>
        <p class="mt-3.5 text-[0.98rem] text-[var(--text-muted)] sm:text-[1.04rem]">{copy.hero.subtitle}</p>
        <p class="mt-3 max-w-[44rem] text-sm leading-[1.6rem] text-[var(--text-muted)] sm:text-[0.98rem]">
          {copy.hero.description}
        </p>
        <div class="mt-4 flex flex-wrap gap-2.5">
          <Button href={getCollectionPath("writing", lang)}>{copy.hero.primaryCta}</Button>
          <Button href={getCollectionPath("projects", lang)} variant="secondary">
            {copy.hero.secondaryCta}
          </Button>
        </div>
      </div>

      <div class="lg:justify-self-end">
        <div class="soft-panel overflow-hidden rounded-[1.35rem] p-2.5">
          <div class="rounded-[1rem] border border-[rgba(216,202,186,0.65)] bg-[rgba(255,250,242,0.74)] p-2">
            <img
              src={PROFILE_AVATAR_SRC}
              alt="sikm avatar"
              class="aspect-[4/3] w-full rounded-[0.85rem] border border-[rgba(216,202,186,0.58)] object-cover lg:aspect-square"
              loading="lazy"
            />
          </div>

          <div class="mt-2.5 rounded-[1rem] border border-[rgba(216,202,186,0.52)] bg-[rgba(255,253,248,0.76)] p-3.5">
            <p class="eyebrow">{copy.labels.currentFocus}</p>
            <h2 class="mt-1.5 text-base font-semibold text-[var(--text-main)]">
              {copy.home.focusTitle}
            </h2>
            <p class="mt-1.5 text-xs leading-5 text-[var(--text-muted)]">{copy.home.focusDescription}</p>
            <div class="mt-2.5 flex flex-wrap gap-1.5">
              {copy.currentFocus.slice(0, 2).map((item) => (
                <Badge compact>{item}</Badge>
              ))}
              {copy.currentFocus.length > 2 && <Badge compact>{`+${copy.currentFocus.length - 2}`}</Badge>}
            </div>

            <div class="mt-3 border-t border-[rgba(216,202,186,0.4)] pt-2.5">
              <p class="text-[0.72rem] font-medium uppercase tracking-[0.08em] text-[var(--text-subtle)]">
                Links
              </p>
              <div class="mt-2 flex flex-wrap gap-1.5">
                <a
                  href={GITHUB_URL}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center rounded-full border border-[rgba(216,202,186,0.72)] bg-[rgba(255,253,248,0.9)] px-2.5 py-1 text-xs font-medium text-[var(--text-muted)] transition hover:border-[rgba(200,111,74,0.32)] hover:text-[var(--text-main)]"
                >
                  GitHub
                </a>
                <a
                  href={BILIBILI_URL}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center rounded-full border border-[rgba(216,202,186,0.72)] bg-[rgba(255,253,248,0.9)] px-2.5 py-1 text-xs font-medium text-[var(--text-muted)] transition hover:border-[rgba(200,111,74,0.32)] hover:text-[var(--text-main)]"
                >
                  Bilibili
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<section class="section-band py-7 lg:py-8">
  <Container>
    <div class="flex flex-wrap items-end justify-between gap-4">
      <SectionTitle
        title={copy.collections.writing.title}
        description={copy.home.writingDescription}
      />
      <a
        href={getCollectionPath("writing", lang)}
        class="inline-flex items-center rounded-full border border-[rgba(216,202,186,0.82)] bg-[rgba(255,253,248,0.78)] px-4 py-2 text-sm font-medium text-[var(--text-muted)] transition hover:border-[rgba(200,111,74,0.32)] hover:text-[var(--text-main)]"
      >
        {moreLabel}
      </a>
    </div>

    <div class="mt-5 grid gap-4 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.35fr)] lg:items-stretch">
      {
        primaryBlog && (
          <ArticleCard
            href={getBlogEntryPath(lang, primaryBlog)}
            title={primaryBlog.data.title}
            summary={primaryBlog.data.summary}
            publishedAt={primaryBlog.data.publishedAt}
            tags={primaryBlog.data.tags}
            readTime={primaryBlog.data.readTime}
            lang={lang}
            cover={primaryBlog.data.cover}
            coverAlt={primaryBlog.data.coverAlt}
          />
        )
      }
      <div class="grid gap-4 sm:grid-cols-2">
        {secondaryBlog.map((entry) => (
          <ArticleCard
            href={getBlogEntryPath(lang, entry)}
            title={entry.data.title}
            summary={entry.data.summary}
            publishedAt={entry.data.publishedAt}
            tags={entry.data.tags}
            readTime={entry.data.readTime}
            lang={lang}
            variant="compact"
          />
        ))}
      </div>
    </div>

    <div class="mt-8 border-t border-[rgba(216,202,186,0.45)] pt-7">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <SectionTitle
          title={copy.collections.projects.title}
          description={copy.home.projectsDescription}
        />
        <a
          href={getCollectionPath("projects", lang)}
          class="inline-flex items-center rounded-full border border-[rgba(216,202,186,0.82)] bg-[rgba(255,253,248,0.78)] px-4 py-2 text-sm font-medium text-[var(--text-muted)] transition hover:border-[rgba(200,111,74,0.32)] hover:text-[var(--text-main)]"
        >
          {moreLabel}
        </a>
      </div>
      <div class="mt-5 grid gap-4 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.35fr)] lg:items-stretch">
        {
          primaryProject && (
            <ProjectCard
              href={getEntryPath("projects", lang, primaryProject)}
              title={primaryProject.data.title}
              summary={primaryProject.data.summary}
              stack={primaryProject.data.stack}
              publishedAt={primaryProject.data.publishedAt}
              lang={lang}
              cover={primaryProject.data.cover}
              coverAlt={primaryProject.data.coverAlt}
              repoUrl={primaryProject.data.repoUrl}
              demoUrl={primaryProject.data.demoUrl}
              showStatus={false}
              variant="horizontal"
            />
          )
        }
        <div class="grid gap-4 sm:grid-cols-2">
          {secondaryProjects.map((entry) => (
            <ProjectCard
              href={getEntryPath("projects", lang, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              stack={entry.data.stack}
              publishedAt={entry.data.publishedAt}
              lang={lang}
              repoUrl={entry.data.repoUrl}
              demoUrl={entry.data.demoUrl}
              showStatus={false}
              variant="compact"
            />
          ))}
        </div>
      </div>
    </div>

    {latestLife.length > 0 && (
      <div class="mt-8 border-t border-[rgba(216,202,186,0.45)] pt-7">
        <SectionTitle
          eyebrow={copy.labels.latest}
          title={copy.home.lifeTitle}
          description={copy.home.lifeDescription}
        />
        <div class="mt-5 grid gap-4 md:grid-cols-3">
          {latestLife.map((entry) => (
            <ArticleCard
              href={getEntryPath("life", lang, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              publishedAt={entry.data.publishedAt}
              tags={entry.data.tags}
              readTime={entry.data.readTime}
              lang={lang}
              cover={entry.data.cover}
              coverAlt={entry.data.coverAlt}
              variant="compact"
            />
          ))}
        </div>
      </div>
    )}
  </Container>
</section>
