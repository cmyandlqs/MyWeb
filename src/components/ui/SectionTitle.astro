---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[var(--text-main)] sm:text-3xl">
    {title}
  </h2>
  {description && <p class="mt-3 text-base text-[var(--text-muted)]">{description}</p>}
</div>
