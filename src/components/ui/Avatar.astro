---
interface Props {
  src: string;
  alt: string;
  compact?: boolean;
}

const { src, alt, compact = false } = Astro.props;
---

<div class:list={[
  "soft-panel overflow-hidden",
  compact ? "rounded-[1.45rem] p-2" : "rounded-[1.75rem] p-2.5",
]}>
  <img
    src={src}
    alt={alt}
    class:list={[
      "aspect-square w-full border border-[rgba(216,202,186,0.65)] object-cover",
      compact ? "rounded-[1.1rem]" : "rounded-[1.3rem]",
    ]}
    loading="lazy"
  />
</div>
