---
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="soft-panel overflow-hidden rounded-[2rem] p-3">
  <img
    src={src}
    alt={alt}
    class="aspect-square w-full rounded-[1.45rem] border border-[rgba(216,202,186,0.65)] object-cover"
    loading="lazy"
  />
</div>
