---
import Container from "./Container.astro";
import LanguageSwitch from "../ui/LanguageSwitch.astro";
import { ui } from "../../i18n/ui";
import {
  getAboutPath,
  getCollectionPath,
  getHomePath,
  type SiteLang,
} from "../../i18n/utils";

interface Props {
  lang: SiteLang;
  currentPath: string;
  translationHref?: string;
}

const { lang, currentPath, translationHref } = Astro.props;
const copy = ui[lang];

const navItems = [
  { href: getCollectionPath("writing", lang), label: copy.nav.writing, key: "writing" },
  { href: getCollectionPath("projects", lang), label: copy.nav.projects, key: "projects" },
  { href: getCollectionPath("research", lang), label: copy.nav.research, key: "research" },
  { href: getCollectionPath("life", lang), label: copy.nav.life, key: "life" },
  { href: getAboutPath(lang), label: copy.nav.about, key: "about" },
];

const isActive = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="sticky top-0 z-40 border-b border-[rgba(216,202,186,0.55)] bg-[rgba(247,244,237,0.82)] backdrop-blur-xl">
  <Container>
    <div class="flex min-h-16 items-center justify-between gap-4 py-3">
      <a
        href={getHomePath(lang)}
        class="text-sm font-semibold tracking-[0.12em] text-[var(--text-main)] uppercase"
      >
        sikm
      </a>

      <nav class="hidden items-center gap-5 text-sm text-[var(--text-muted)] md:flex">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "transition-colors duration-200 hover:text-[var(--text-main)]",
              isActive(item.href) && "text-[var(--text-main)]",
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2 text-sm">
        <LanguageSwitch href={translationHref} label={copy.nav.languageSwitch} />
      </div>
    </div>
  </Container>
</header>
