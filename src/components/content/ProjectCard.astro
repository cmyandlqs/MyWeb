---
import Badge from "../ui/Badge.astro";

interface Props {
  href: string;
  title: string;
  summary: string;
  status: string;
  stack: string[];
  cover?: string;
  coverAlt?: string;
  repoUrl?: string;
  demoUrl?: string;
}

const {
  href,
  title,
  summary,
  status,
  stack,
  cover,
  coverAlt = "",
  repoUrl,
  demoUrl,
} = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden rounded-[1.5rem] border border-[rgba(216,202,186,0.78)] bg-[rgba(255,253,248,0.94)] transition duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-soft)]">
  {cover && (
    <a href={href} class="border-b border-[rgba(216,202,186,0.58)]">
      <img src={cover} alt={coverAlt} class="aspect-[16/9] w-full object-cover" loading="lazy" />
    </a>
  )}
  <div class="flex flex-1 flex-col gap-4 p-5">
    <div class="flex items-center justify-between gap-3">
      <h3 class="text-xl font-semibold tracking-tight text-[var(--text-main)]">
        <a href={href} class="transition-colors group-hover:text-[var(--accent-muted)]">
          {title}
        </a>
      </h3>
      <Badge tone="accent">{status}</Badge>
    </div>
    <p class="text-sm leading-7 text-[var(--text-muted)]">{summary}</p>
    <div class="mt-auto flex flex-col gap-3">
      <div class="flex flex-wrap gap-2">
        {stack.slice(0, 5).map((item) => <Badge>{item}</Badge>)}
      </div>
      <div class="flex flex-wrap gap-4 text-sm text-[var(--text-muted)]">
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noreferrer" class="hover:text-[var(--text-main)]">
            GitHub
          </a>
        )}
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noreferrer" class="hover:text-[var(--text-main)]">
            Demo
          </a>
        )}
      </div>
    </div>
  </div>
</article>
