---
import ArticleCard from "./ArticleCard.astro";
import ProjectCard from "./ProjectCard.astro";
import Container from "../layout/Container.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import { ui } from "../../i18n/ui";
import {
  getBlogEntryPath,
  getEntryPath,
  getPublishedBlogEntries,
  getPublishedEntries,
} from "../../lib/content/translations";
import { type SiteCollection, type SiteLang } from "../../i18n/utils";

interface Props {
  collection: SiteCollection;
  lang: SiteLang;
}

const { collection, lang } = Astro.props;
const copy = ui[lang];
const entries = collection === "writing"
  ? await getPublishedBlogEntries(lang)
  : await getPublishedEntries(collection, lang);
---

<section class="pb-20 pt-14">
  <Container>
    <SectionTitle
      eyebrow={copy.labels.latest}
      title={copy.collections[collection].title}
      description={copy.collections[collection].description}
    />

    {
      entries.length === 0 ? (
        <div class="soft-panel mt-8 rounded-[1.5rem] p-8 text-[var(--text-muted)]">
          {copy.collections[collection].empty}
        </div>
      ) : collection === "projects" ? (
        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {entries.map((entry) => (
            <ProjectCard
              href={getEntryPath("projects", lang, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              status={entry.data.status}
              stack={entry.data.stack}
              cover={entry.data.cover}
              coverAlt={entry.data.coverAlt}
              repoUrl={entry.data.repoUrl}
              demoUrl={entry.data.demoUrl}
            />
          ))}
        </div>
      ) : (
        <div class="mt-8 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
          {entries.map((entry) => (
            <ArticleCard
              href={collection === "writing" ? getBlogEntryPath(lang, entry) : getEntryPath(collection, lang, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              publishedAt={entry.data.publishedAt}
              tags={entry.data.tags}
              readTime={entry.data.readTime}
              lang={lang}
              cover={entry.data.cover}
              coverAlt={entry.data.coverAlt}
            />
          ))}
        </div>
      )
    }
  </Container>
</section>
