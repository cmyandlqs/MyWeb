---
import Badge from "../ui/Badge.astro";
import { formatDate, type SiteLang } from "../../i18n/utils";

interface Props {
  href: string;
  title: string;
  summary: string;
  publishedAt: string;
  tags?: string[];
  readTime?: string;
  lang: SiteLang;
  cover?: string;
  coverAlt?: string;
  variant?: "default" | "compact";
}

const {
  href,
  title,
  summary,
  publishedAt,
  tags = [],
  readTime,
  lang,
  cover,
  coverAlt = "",
  variant = "default",
} = Astro.props;

const visibleTags = tags.slice(0, variant === "compact" ? 2 : 3);
const hiddenTagCount = Math.max(tags.length - visibleTags.length, 0);
const hasCover = variant === "default" && cover;
---

<article class:list={[
  "group flex h-full flex-col overflow-hidden border border-[rgba(216,202,186,0.78)] bg-[rgba(255,253,248,0.92)] transition duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-soft)]",
  variant === "compact" ? "rounded-[1.1rem]" : "rounded-[1.35rem]",
]}>
  {hasCover && (
    <a href={href} class="border-b border-[rgba(216,202,186,0.58)]">
      <img src={cover} alt={coverAlt} class="h-32 w-full object-cover sm:h-36" loading="lazy" />
    </a>
  )}
  <div class:list={[
    "flex flex-1 flex-col",
    variant === "compact" ? "gap-2.5 p-3.5 sm:p-4" : "gap-3 p-4 sm:p-5",
  ]}>
    <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--text-subtle)]">
      <span>{formatDate(publishedAt, lang)}</span>
      {readTime && (
        <>
          <span>·</span>
          <span>{readTime}</span>
        </>
      )}
    </div>
    <div class:list={[variant === "compact" ? "space-y-2" : "space-y-2.5"]}>
      <h3 class:list={[
        "font-semibold tracking-tight text-[var(--text-main)]",
        variant === "compact"
          ? "text-base [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2] overflow-hidden"
          : "text-lg sm:text-xl [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2] overflow-hidden",
      ]}>
        <a href={href} class="transition-colors group-hover:text-[var(--accent-muted)]">
          {title}
        </a>
      </h3>
      <p class:list={[
        "text-sm text-[var(--text-muted)] [display:-webkit-box] [-webkit-box-orient:vertical] overflow-hidden",
        variant === "compact" ? "leading-[1.45rem] [-webkit-line-clamp:2]" : "leading-6 [-webkit-line-clamp:2]",
      ]}>
        {summary}
      </p>
    </div>
    {tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-2">
        {visibleTags.map((tag) => <Badge compact>{tag}</Badge>)}
        {hiddenTagCount > 0 && <Badge compact>{`+${hiddenTagCount}`}</Badge>}
      </div>
    )}
  </div>
</article>
