---
import Badge from "../ui/Badge.astro";
import { formatDate, type SiteLang } from "../../i18n/utils";

interface Props {
  href: string;
  title: string;
  summary: string;
  publishedAt: string;
  tags?: string[];
  readTime?: string;
  lang: SiteLang;
  cover?: string;
  coverAlt?: string;
}

const {
  href,
  title,
  summary,
  publishedAt,
  tags = [],
  readTime,
  lang,
  cover,
  coverAlt = "",
} = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden rounded-[1.4rem] border border-[rgba(216,202,186,0.78)] bg-[rgba(255,253,248,0.92)] transition duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-soft)]">
  {cover && (
    <a href={href} class="border-b border-[rgba(216,202,186,0.58)]">
      <img src={cover} alt={coverAlt} class="aspect-[16/9] w-full object-cover" loading="lazy" />
    </a>
  )}
  <div class="flex flex-1 flex-col gap-4 p-5">
    <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--text-subtle)]">
      <span>{formatDate(publishedAt, lang)}</span>
      {readTime && (
        <>
          <span>·</span>
          <span>{readTime}</span>
        </>
      )}
    </div>
    <div class="space-y-3">
      <h3 class="text-xl font-semibold tracking-tight text-[var(--text-main)]">
        <a href={href} class="transition-colors group-hover:text-[var(--accent-muted)]">
          {title}
        </a>
      </h3>
      <p class="text-sm leading-7 text-[var(--text-muted)]">{summary}</p>
    </div>
    {tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-2">
        {tags.slice(0, 4).map((tag) => <Badge>{tag}</Badge>)}
      </div>
    )}
  </div>
</article>
