---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../../layouts/ArticleLayout.astro";
import { getCollectionPath } from "../../../i18n/utils";
import {
  getEntryPath,
  getTranslatedEntry,
} from "../../../lib/content/translations";

export async function getStaticPaths() {
  const entries = await getCollection(
    "writing",
    ({ data }) => !data.draft && data.lang === "en",
  );

  return entries.map((entry) => ({
    params: { slug: entry.data.routeSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const translation = await getTranslatedEntry("writing", entry, "zh-CN");
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.summary}
  lang="en"
  currentPath={Astro.url.pathname}
  translationHref={translation ? getEntryPath("writing", "zh-CN", translation) : getCollectionPath("writing", "zh-CN")}
  collection="writing"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  readTime={entry.data.readTime}
  tags={entry.data.tags}
  cover={entry.data.cover}
  coverAlt={entry.data.coverAlt}
  backHref={getCollectionPath("writing", "en")}
>
  <Content />
</ArticleLayout>
