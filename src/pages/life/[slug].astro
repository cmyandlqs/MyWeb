---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getCollectionPath } from "../../i18n/utils";
import {
  getEntryPath,
  getTranslatedEntry,
} from "../../lib/content/translations";

export async function getStaticPaths() {
  const entries = await getCollection(
    "life",
    ({ data }) => !data.draft && data.lang === "zh-CN",
  );

  return entries.map((entry) => ({
    params: { slug: entry.data.routeSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const translation = await getTranslatedEntry("life", entry, "en");
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.summary}
  lang="zh-CN"
  currentPath={Astro.url.pathname}
  translationHref={translation ? getEntryPath("life", "en", translation) : getCollectionPath("life", "en")}
  collection="life"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  readTime={entry.data.readTime}
  tags={entry.data.tags}
  cover={entry.data.cover}
  coverAlt={entry.data.coverAlt}
  backHref={getCollectionPath("life", "zh-CN")}
>
  <Content />
</ArticleLayout>
