---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import {
  getCollectionPath,
} from "../../i18n/utils";
import {
  getBlogEntryPath,
  getTranslatedBlogEntry,
  type BlogEntry,
  type BlogSourceCollection,
} from "../../lib/content/translations";

export async function getStaticPaths() {
  const [writingEntries, researchEntries] = await Promise.all([
    getCollection(
      "writing",
      ({ data }) => !data.draft && data.lang === "zh-CN",
    ),
    getCollection(
      "research",
      ({ data }) => !data.draft && data.lang === "zh-CN",
    ),
  ]);

  const entries = [
    ...writingEntries.map((entry) => ({ entry, sourceCollection: "writing" as const })),
    ...researchEntries.map((entry) => ({ entry, sourceCollection: "research" as const })),
  ];

  return entries.map(({ entry, sourceCollection }) => ({
    params: { slug: entry.data.routeSlug },
    props: { entry, sourceCollection },
  }));
}

const { entry, sourceCollection } = Astro.props as {
  entry: BlogEntry;
  sourceCollection: BlogSourceCollection;
};
const { Content } = await render(entry);
const translation = await getTranslatedBlogEntry(sourceCollection, entry, "en");
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.summary}
  lang="zh-CN"
  currentPath={Astro.url.pathname}
  translationHref={translation ? getBlogEntryPath("en", translation) : getCollectionPath("writing", "en")}
  collection="writing"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  readTime={entry.data.readTime}
  tags={entry.data.tags}
  cover={entry.data.cover}
  coverAlt={entry.data.coverAlt}
  backHref={getCollectionPath("writing", "zh-CN")}
>
  <Content />
</ArticleLayout>
