---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import { ui } from "../i18n/ui";
import { formatDate, type SiteLang } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  lang: SiteLang;
  currentPath: string;
  translationHref?: string;
  publishedAt: string;
  updatedAt?: string;
  status: string;
  stack: string[];
  cover?: string;
  coverAlt?: string;
  repoUrl?: string;
  demoUrl?: string;
  caseStudyUrl?: string;
  backHref: string;
}

const {
  title,
  description,
  lang,
  currentPath,
  translationHref,
  publishedAt,
  updatedAt,
  status,
  stack,
  cover,
  coverAlt = "",
  repoUrl,
  demoUrl,
  caseStudyUrl,
  backHref,
} = Astro.props;

const copy = ui[lang];
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  currentPath={currentPath}
  translationHref={translationHref}
>
  <section class="pb-20 pt-14">
    <Container>
      <div class="mx-auto max-w-5xl">
        <Button href={backHref} variant="secondary">{copy.labels.backToList}</Button>
        <div class="mt-8 grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <div>
            <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--text-subtle)]">
              <span>{formatDate(publishedAt, lang)}</span>
              {updatedAt && (
                <>
                  <span>·</span>
                  <span>
                    {copy.labels.updatedAt} {formatDate(updatedAt, lang)}
                  </span>
                </>
              )}
            </div>
            <h1 class="mt-5 text-4xl font-semibold tracking-tight text-[var(--text-main)] sm:text-5xl">
              {title}
            </h1>
            <p class="mt-5 text-lg leading-8 text-[var(--text-muted)]">{description}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              <Badge tone="accent">{status}</Badge>
              {stack.map((item) => <Badge>{item}</Badge>)}
            </div>
            <div class="mt-8 flex flex-wrap gap-3">
              {repoUrl && (
                <Button href={repoUrl} target="_blank" rel="noreferrer">
                  {copy.labels.github}
                </Button>
              )}
              {demoUrl && (
                <Button href={demoUrl} target="_blank" rel="noreferrer" variant="secondary">
                  {copy.labels.demo}
                </Button>
              )}
              {caseStudyUrl && (
                <Button href={caseStudyUrl} target="_blank" rel="noreferrer" variant="secondary">
                  {copy.labels.caseStudy}
                </Button>
              )}
            </div>
          </div>

          {cover && (
            <img
              src={cover}
              alt={coverAlt}
              class="rounded-[1.8rem] border border-[rgba(216,202,186,0.78)] bg-white shadow-[var(--shadow-soft)]"
            />
          )}
        </div>
        <article class="rich-content mx-auto mt-12 max-w-3xl">
          <slot />
        </article>
      </div>
    </Container>
  </section>
</BaseLayout>
